---
import "sakura.css/css/sakura-earthly.css";
// import 'sakura.css/css/sakura-dark.css';
import { themaStyle } from "../styles/thema.css";
import { SEO } from "astro-seo";
import { Icon } from "astro-icon";
import IconLink from "../components/IconLink.astro";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ja">
  <SEO
    charset="UTF-8"
    title={title}
    extend={{
      link: [{ rel: "icon", href: "/favicon.svg", type: "image/svg+xml" }],
      meta: [
        { name: "generator", content: Astro.generator },
        { name: "viewport", content: "width=device-width" },
      ],
    }}
  />
  <body class={themaStyle}>
    <header class="header">
      <a href="/" class="siteTopAnchor">
        <h1>blog.tsuki-lab.net</h1>
      </a>
      <nav class="nav">
        <IconLink
          href="https://zenn.dev/rabbit"
          iconName="simple-icons:zenn"
          aria-label="Zenn"
        />
        <IconLink
          href="https://twitter.com/hanetsuki_dev"
          iconName="simple-icons:twitter"
          aria-label="Twitter"
        />
        <IconLink
          href="https://github.com/tsuki-lab"
          iconName="simple-icons:github"
          aria-label="GitHub"
        />
      </nav>
    </header>
    <slot />
    <footer class="footer">
      <p class="analyticsMessage">
        このサイトは、<a
          href="https://policies.google.com/technologies/partner-sites?hl=ja"
          target="_blank">Google Analytics</a
        >を使用しています。
      </p>
      <small>©2023 tsuki-lab</small>
    </footer>
    <style lang="scss">
      .siteTopAnchor {
        color: #222222 !important;
        &:hover {
          border-bottom: none;
        }
      }

      .header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        @media screen and (max-width: 684px) {
          display: block;
        }
      }

      .nav {
        display: flex;
        gap: 20px;
      }

      .analyticsMessage {
        margin-bottom: 0.8rem;
        font-size: 1.53rem;
        @media (max-width: 382px) {
          font-size: 1.35rem;
        }
      }

      .icon {
        color: #222222 !important;
        width: 32px;
        display: block;
        @media screen and (max-width: 684px) {
          width: 28px;
        }
        &:hover {
          border-bottom: none;
        }
      }

      .footer {
        padding-top: 1.6rem;
        border-top: 1px solid #c8c9cc;
        color: #4a4b4e;
      }
    </style>
  </body>
</html>
